# Database connection mode: cloud (default) or local
DB_CONNECTION_MODE=cloud

# --- Oracle Cloud (wallet) ---
DB_USER=ADMIN
DB_PASSWORD=ReplaceWithStrongPassword
TNS_NAME=csatbm_high
WALLET_PATH=/app/wallet
WALLET_PASSWORD=ReplaceWithWalletPassword

# --- Oracle Local Fallback (used only when DB_CONNECTION_MODE=local) ---
DB_HOST=oracle
DB_PORT=1521
DB_SERVICE=XEPDB1
DB_CONTAINER_NAME=oracle-xe
DB_ROOT_PASSWORD=ReplaceWithRootPassword

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_EXPIRES_IN=8h

# --- Crypto ---
# Generate each value separately
AES_MASTER_KEY=REPLACE_WITH_64_CHAR_HEX

# --- App-layer transport crypto (phase 7 rollout) ---
# Keep false until client envelope flow is enabled.
APP_LAYER_CRYPTO_ENABLED=false
APP_LAYER_CRYPTO_MAX_SKEW_MS=120000
# Preferred for manual RSA mode (hex, no 0x prefix)
RSA_N_HEX=
RSA_E_HEX=010001
RSA_D_HEX=
# Option 1: provide PEM directly (escape newlines with \n)
RSA_PUBLIC_KEY_PEM=
RSA_PRIVATE_KEY_PEM=
# Option 2: provide file paths (preferred in production)
RSA_PUBLIC_KEY_PATH=
RSA_PRIVATE_KEY_PATH=

# --- Dev monitor (default OFF) ---
ENABLE_CRYPTO_MONITOR=false
CRYPTO_MONITOR_TOKEN=
MONITOR_URL=http://localhost:3003

# --- App ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3002
